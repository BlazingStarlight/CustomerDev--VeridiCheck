# Clave de API para Google Gemini (Obtenla gratis en https://aistudio.google.com/)
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Modelo estable usado por defecto. Puedes cambiarlo sin modificar el código.
GEMINI_MODEL=gemini-3.5-flash

# Correo mediante EmailJS (https://www.emailjs.com/)
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
