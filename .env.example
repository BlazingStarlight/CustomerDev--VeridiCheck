# Clave de API para Google Gemini (Obtenla gratis en https://aistudio.google.com/)
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Modelo estable usado por defecto. Puedes cambiarlo sin modificar el código.
GEMINI_MODEL=gemini-3.5-flash

# Configuraciones opcionales de Twilio para enviar mensajes de WhatsApp automáticamente.
# Si no las configuras, la app usará el enlace de WhatsApp Web precargado en la interfaz.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SENDER_NUMBER=whatsapp:+14155238886
